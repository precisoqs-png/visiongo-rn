{
  "expo": {
    "name": "VisionGo",
    "slug": "visiongo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "visiongo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "githubUrl": "https://github.com/precisoqs-png/visiongo-rn",
    "splash": {
      "backgroundColor": "#f3ecdd"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.visiongo.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f3ecdd"
      },
      "package": "com.visiongo.app"
    },
    "web": {
      "bundler": "metro",
      "output": "server",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-haptics",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#f3ecdd"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,h
          "resizeMode": "contain",
          "backgroundColor": "#f3ecdd"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "9ed9ce80-53a2-4ac5-9fb8-dda4ee23a467"
      }
    }
  }
}
