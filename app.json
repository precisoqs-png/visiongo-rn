{
  "expo": {
    "name": "VisionGo",
    "slug": "visiongo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "visiongo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#f3ecdd"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.visiongo.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f3ecdd"
      },
      "package": "com.visiongo.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-haptics"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
